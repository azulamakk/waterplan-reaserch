ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Search Provider (pick one, priority order) ---
# Option 1: SearXNG self-hosted (recommended for scale — free, unlimited)
#   docker run -d -p 8080:8080 searxng/searxng
# SEARXNG_URL=http://localhost:8080

# Option 2: Brave Search API (2,000 free queries/month)
#   https://api.search.brave.com/
# BRAVE_SEARCH_API_KEY=

# Option 3: Serper.dev (2,500 free queries on signup, then $0.001/query)
#   https://serper.dev
# SERPER_API_KEY=

# Option 4: DuckDuckGo — default, no config needed (rate-limited, not for scale)

# Optional
# WATERPLAN_CACHE_DIR=~/.waterplan/cache
# WATERPLAN_CACHE_TTL_HOURS=24
